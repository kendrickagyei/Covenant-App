# Path to the SQLite database file (relative to the server directory).
DATABASE_PATH=./data/covenant.db
PORT=3001

# Comma-separated browser origins allowed to call the API.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Required in production. When set in development, POST/PUT/DELETE requests
# must include either X-API-Key: <value> or Authorization: Bearer <value>.
API_KEY=change-me

JSON_BODY_LIMIT=100kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# Frontend sets VITE_API_URL in its .env to point here (defaults to http://localhost:3001).
